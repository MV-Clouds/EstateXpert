* {
    font-family: 'Mulish', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    user-select: none;
}

.blue-header {
    background: linear-gradient(135deg, #FFFFFF 0%, #E3F2FD 100%);
    color: #1F2937;
    border-bottom: 1px solid #E5E7EB;
    border-top-left-radius: 12px !important;
    border-top-right-radius: 12px !important;
    padding: 1.5rem !important;
}

.blue-header h1 {
    font-size: 20px;
    font-weight: 600;
    color: #1F2937;
}

.footerbtns {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    background: #FFFFFF;
    border-top: 1px solid #E5E7EB;
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
}

.cancel_btn_css {
    font-size: 14px;
    font-weight: 500;
    padding: 0.625rem 1.5rem;
    background: #FFFFFF;
    border: 1.5px solid #0176D3;
    color: #0176D3;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s ease;
}

.cancel_btn_css:hover {
    background: #F3F6F9;
    box-shadow: 0 2px 4px rgba(1, 118, 211, 0.15);
}

.save_btn_css {
    font-size: 14px;
    font-weight: 500;
    padding: 0.625rem 1.5rem;
    border: none;
    background: #0176D3;
    color: white;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s ease;
}

.save_btn_css:hover:not(:disabled) {
    background: #0156A3;
    box-shadow: 0 4px 8px rgba(1, 118, 211, 0.25);
    transform: translateY(-1px);
}

.save_btn_css:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.flex_css {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border: 2px dashed #CBD5E1;
    border-radius: 8px;
    background: #FFFFFF;
    padding: 2rem;
    transition: all 0.3s ease;
}

.flex_css:hover {
    border-color: #0176D3;
    background: #F8FAFC;
}

.images_upcss {
    display: flex;
    flex-direction: row;
    gap: 4px;
    font-family: Inter;
    font-size: 14px;
    line-height: 20px;
}

.images_upcss label span {
    color: #0176D3;
    cursor: pointer;
}

.progress {
    width: 100%;
    background-color: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    padding: 1rem;
}

progress {
    width: 100%;
    height: 8px;
    border-radius: 4px;
}

progress::-webkit-progress-bar {
    background-color: #E5E7EB;
    border-radius: 4px;
}

progress::-webkit-progress-value {
    background: linear-gradient(90deg, #0176D3, #0284C7);
    border-radius: 4px;
}

progress::-moz-progress-bar {
    background: linear-gradient(90deg, #0176D3, #0284C7);
    border-radius: 4px;
}

.slds-backdrop_open {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.6);
    z-index: 9000;
}

.lightningPillCss {
    gap: 0.5rem;
    display: flex;
    flex-direction: column;
}

@media only screen and (max-width: 500px) {
    * {
        font-size: 0.7rem;
    }

    .blue-header {
        font-size: 20px;
        font-weight: 600;
        line-height: 12.89px;
    }

    .watermark_container {
        font-size: 14px !important;
        font-weight: 400 !important;
        line-height: 16.8px !important;
        text-align: left;
    }

    .label_css {
        font-size: 14px !important;
        font-weight: 600 !important;
        line-height: 12.89px !important;
        text-align: left;
    }

    .tab-menu ul li a {
        padding: 5px 10px !important;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .tab {
        height: 15rem !important;
    }
}

.tab {
    display: none;
    animation: fadeIn 0.5s ease-in-out;
    height: 20rem;
    overflow: auto;
}

.tab-container {
    height: 100%;
    width: 100%;
    padding-b4px;
    margin: 0;
    justify-content: space-around;
    width: 100%;
    border-radius: 8px;
    background: #E5E7EB;
    user-select: none;
}

.tab-menu ul li {
    display: inline-block;
    list-style-type: none;
    flex-grow: 1;
    width: 50%;
}

.tab-menu ul li a {
    font-style: normal;
    font-weight: 500;
    font-size: 14px;
    display: block;
    padding: 0.625rem 1rem;
    text-align: center;
    text-decoration: none;
    color: #6B7280;
    transition: all 0.2s ease;
    cursor: pointer;
    border-radius: 6px;
}

.tab-menu ul li a.active-tab {
    color: #FFFFFF;
    background: #0176D3;
    box-shadow: 0 2px 4px rgba(1, 118, 211, 0.2
    cursor: pointer;
}

.tab-menu ul li a.active-tab {
    color: white;
    border-radius: 5px;
    background: linear-gradient(90deg, #1565c0, #81d4fa);
}

.active-tab-content {
    display: block;
}

.images_upcss {
    display: flex;
    flex-dire.5px solid #0176D3;
    background: #FFFFFF;
    color: #0176D3;
    padding: 0.625rem 2rem;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.2s ease;
}

.images_upcss label:hover {
    background: #0176D3;
    color: #FFFFFF;
    box-shadow: 0 4px 8px rgba(1, 118, 211, 0.25);
    transform: translateY(-1px)
.images_upcss label {
    border: 1px solid #0276D3;
    background: #fff;
    color: #0276D3;
    padding: 10px 6rem;
    border-radius: 5px;
    cursor: pointer;
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }

    to {
        opacity: 1;
    }
}

.modalbody {
    background-color: #F9FAFB !important;
    padding: 1.5rem !important;
    min-height: 300px;
}

.slds-modal__container {
    border-radius: 12px !important;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04) !important;
}
1rem;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    font-size: 14px;
    font-weight: 400;
    line-height: 24px;
    text-align: left;
    color: #374151;
}

.label_css {
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    text-align: left;
    padding-left: 2px;
    color: #1F2937
}

.label_css {
    font-size: 15px;
    font-weight: 400;
    line-height: 20px;
    text-align: left;
    padding-left: 5px;
}

.tab lightning-input,
.tab lightning-combobox {
    padding: 5px;
}

.tab-menu {
    border-radius: 5px;
    padding-bottom: 20px;
}

.file_view_upload {
    padding-top: 20px;
    overflow: hidden;
}

.upload_icon_css {
    font-size: 15px;
    font-weight: 400;
    line-height: 20px;
    text-align: left;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.upload_icon_css lightning-icon {
    padding-right: 5px;
}

.closs_icon_css {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    background: #F3F6F9;
    transition: all 0.2s ease;
    position: absolute;
    right: 1rem;
    top: 1.25rem;
}

.closs_icon_css:hover {
    background: #E5E7EB;
    transform: scale(1.05);
}

.closs_icon_css svg path {
    fill: #1F2937
    background: transparent;
}
flex-direction: row;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    width: 100%;
    padding: 0.875rem;
    background: #FFFFFF;
    transition: all 0.2s ease;
}

.container:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    border-color: #CBD5E1
    display: flex;
    /* flex-wrap: wrap; */
    flex-direction: row;
    border: solid 1px #E7E7E7;
    border-radius: 1rem;
    width: 100%;
    padding: 1rem;
    background: #fff;
}

.box1 {
    width: 75%;
    padding: 5px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.box1 p {
    white-space: nowrap;
    width: 90%;
    text-overflow: ellipsis;
    overflow: hidden;
}

.removeImage {
    width: 10%;
    display: flex;
    justify-content: center;
    align-items: center;
}

.removeImage svg {
    cursor: pointer;
}

.removeImage p {
    margin-bottom: 3px;
}

.imgd1 {
    font-family: Inter;
    font-size: 14px;
    font-weight: 600;
    line-height: 18px;
    text-align: left;
}

.imgd2 {
    font-family: Inter;
    font-size: 14px;
    font-weight: 400;
    line-height: 16px;
    text-align: left;
    color: #6D6D6D;
    padding-top: 3px;
}

.img_css {
    height: 4rem;
    width: 5rem;
    display: flex;
    justify-content: center;
    align-items: center;
}

.img_css img {
    height: -webkit-fill-available;
    width: -webkit-fill-available;
    transition: background-color 0.3s ease;
    border-radius: 4px;
}